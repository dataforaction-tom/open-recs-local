# open-recs-local — environment template
# Copy to .env and fill in. APP_MODE switches the whole app between
# single-user local and multi-user hosted; do not mix.

# ---- Core -----------------------------------------------------------------

# local | hosted
APP_MODE=local

# Postgres (with pgvector) — via docker-compose this is the internal hostname.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/openrecs

# ---- Hosted-mode only (required when APP_MODE=hosted) ---------------------

# Minimum 32 chars. Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Public URL the app is served from.
BETTER_AUTH_URL=http://localhost:3000

# ---- LLM provider ---------------------------------------------------------

# openai-compatible | anthropic | mistral | fake
LLM_PROVIDER=fake
LLM_MODEL=
LLM_API_KEY=
# For openai-compatible providers (Ollama, LM Studio, vLLM, OpenAI).
LLM_BASE_URL=

# ---- Embedding provider ---------------------------------------------------

# openai-compatible | voyage | fake
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
# Must match schema vector(N). Default 768.
EMBEDDING_DIMENSIONS=768

# ---- OCR provider ---------------------------------------------------------

# mistral | docling | firecrawl | tesseract-pdf | fake
OCR_PROVIDER=fake
OCR_API_KEY=
# docling: HTTP endpoint of the docling sidecar.
DOCLING_URL=http://docling:5001

# ---- Storage provider -----------------------------------------------------

# fs | s3
STORAGE_PROVIDER=fs
# fs: filesystem path mounted into app + worker (see compose).
STORAGE_FS_PATH=/data/uploads
# s3 / MinIO:
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
